{
    "$schema": "http://json.schemastore.org/template",
    "author": "Arbeidstilsynet",
    "classifications": [
        "Nuget",
        "Package"
    ],
    "identity": "AT.CommonPackage",
    "name": "Common Package Template",
    "shortName": "common-package",
    "tags": {
        "language": "C#",
        "type": "project"
    },
    "sourceName": "SamplePackage",
    "sources": [
        {
            "modifiers": [
                {
                    "exclude": [
                        "**/[Bb]in/**",
                        "**/[Oo]bj/**",
                        ".template.config/**/*",
                        "**/*.filelist",
                        "**/*.user",
                        "**/*.lock.json",
                        ".idea/**",
                        "pipelines/**",
                        "**/volume/**"
                    ]
                }
            ]
        }
    ]
}