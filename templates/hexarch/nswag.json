{
  "runtime": "Net100",
  "documentGenerator": {
    "fromDocument": {
      "url": "generated/openApi.json"
    }
  },
  "codeGenerators": {
    "openApiToTypeScriptClient": {
      "typeStyle": "Interface",
      "enumStyle": "StringLiteral",
      "generateClientClasses": true,
      "generateClientInterfaces": true,
      "output": "generated/client.ts"
    }
  }
}