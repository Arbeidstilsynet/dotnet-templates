  "components": {
    "schemas": {
      "CreateSakDto": {
        "required": [
          "organisasjonsnummer"
        ],
        "type": "object",
        "properties": {
          "organisasjonsnummer": {
            "pattern": "^\\d{9}$",
            "type": "string",
            "description": "A reference to the organization number associated with the case."
          }
        },
        "description": "Data Transfer Object for creating a new Sak."
      },
      "Sak": {
        "required": [
          "id",
          "organisasjonsnummer",
          "createdAt",
          "deadline",
          "lastUpdated",
          "status"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the case.",
            "format": "uuid"
          },
          "organisasjonsnummer": {
            "type": "string",
            "description": "The organization number associated with the case. It refers to a Norwegian organization."
          },
          "createdAt": {
            "type": "string",
            "description": "The timestamp of case creation.",
            "format": "date-time"
          },
          "deadline": {
            "type": "string",
            "description": "The deadline for finishing the case.",
            "format": "date-time"
          },
          "lastUpdated": {
            "type": "string",
            "description": "The timestamp of the last update.",
            "format": "date-time"
          },
          "status": {
            "description": "The current status of the case.",
            "$ref": "#/components/schemas/SakStatus"
          }
        },
        "description": "Represents a case in this domain."
      },
      "SakStatus": {
        "enum": [
          "New",
          "InProgress",
          "Done",
          "Archived"
        ],
        "type": "string",
        "description": "Enumerates the possible statuses of a case Sak."
      }
    }
  },
  "tags": [
    {
      "name": "Actions"
    },
    {
      "name": "Saker"
    }
  ]
}