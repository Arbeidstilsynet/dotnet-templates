{
  "name": "@HexagonalArchitectureTemplateDocker",
  "version": "0.0.0",
  "private": true,
  "types": "./generated/client.d.ts",
  "exports": {
    ".": {
      "types": "./generated/client.d.ts"
    }
  },
  "scripts": {
    "generate:openapi": "dotnet clean App/App.GenerateOpenApi/App.GenerateOpenApi.csproj && dotnet build App/App.GenerateOpenApi/App.GenerateOpenApi.csproj",
    "generate:ts": "pnpm install && pnpm exec openapi-typescript generated/openApi.json -o generated/client.d.ts",
    "generate:client": "pnpm generate:openapi && pnpm generate:ts"
  },
  "devDependencies": {
    "openapi-typescript": "7.10.1",
    "typescript": "5.9.3"
  }
}
